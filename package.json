{
  "name": "mds-command-centre",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first MDS Command Centre shell reading D-root War Room boards.",
  "bin": {
    "midas": "scripts/midas.mjs"
  },
  "scripts": {
    "doctor": "node scripts/midas.mjs doctor",
    "test:doctor": "node scripts/test-doctor.mjs",
    "test:skill-validator": "node scripts/test-skill-validator.mjs",
    "skills:validate": "node scripts/midas.mjs skills validate",
    "eval": "node scripts/midas.mjs eval",
    "test:plugin-eval": "node scripts/test-plugin-eval.mjs",
    "docs:check": "node scripts/docs-staleness.mjs --staged",
    "test:docs-staleness": "node scripts/test-docs-staleness.mjs",
    "docs:frontmatter": "node scripts/midas.mjs docs validate",
    "test:frontmatter": "node scripts/test-frontmatter-order.mjs",
    "verify:gaps": "node scripts/verification-gap.mjs --staged",
    "test:verification-gap": "node scripts/test-verification-gap.mjs",
    "test:ssrf-guard": "node scripts/test-ssrf-guard.mjs",
    "harness:export": "node scripts/midas.mjs harness export harness-sources/local-proof-review.md",
    "harness:check": "node scripts/midas.mjs harness export harness-sources/local-proof-review.md --check",
    "test:harness-adapter": "node scripts/test-harness-adapter.mjs",
    "workflow:parse": "node scripts/midas.mjs workflow parse workflows/local-proof.checklist.md",
    "test:checklist-workflow": "node scripts/test-checklist-workflow.mjs",
    "release:audit": "node scripts/midas.mjs release audit HEAD~1..HEAD",
    "test:release-audit": "node scripts/test-git-release-audit.mjs",
    "party:list": "node scripts/midas.mjs party list",
    "test:party-room": "node scripts/test-party-room.mjs",
    "test:persona-memory": "node scripts/test-persona-memory.mjs",
    "test:midas-loop": "node scripts/test-midas-loop.mjs",
    "test:orchestration-graph": "node scripts/test-orchestration-graph.mjs",
    "workers:run": "node scripts/midas.mjs workers run workflows/example-subagents.json",
    "test:subagent-engine": "node scripts/test-subagent-engine.mjs",
    "customizer:validate": "node scripts/midas.mjs customizer validate config/agents/developer.toml",
    "test:customizer": "node scripts/test-declarative-customizer.mjs",
    "signals:list": "node scripts/midas.mjs signals list",
    "test:team-signaling": "node scripts/test-team-signaling.mjs",
    "tasks:restructure": "node scripts/midas.mjs tasks restructure workflows/example-task-restructure.json",
    "game:inspect": "node scripts/midas.mjs game inspect .",
    "help": "node scripts/midas.mjs help README.md",
    "test:task-game-help": "node scripts/test-task-game-help.mjs",
    "profile:show": "node scripts/midas.mjs profile show",
    "test:user-profile": "node scripts/test-user-profile-modeler.mjs",
    "hooks:install": "git config --local core.hooksPath .githooks",
    "predev": "npm run doctor",
    "predaemon": "npm run doctor",
    "pretray": "npm run doctor",
    "predesktop": "npm run doctor",
    "refresh-data": "node scripts/refresh-war-room-data.mjs && node scripts/refresh-local-adapters.mjs",
    "dev": "npm run refresh-data && node scripts/serve.mjs --root . --port 5178",
    "build": "npm run refresh-data && node scripts/build-static.mjs",
    "build:static": "node scripts/build-static.mjs",
    "lint": "node scripts/check-static.mjs",
    "preview": "node scripts/serve.mjs --root dist --port 4178",
    "desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File desktop/launch-command-centre.ps1",
    "tray": "powershell -NoProfile -ExecutionPolicy Bypass -File desktop/command-centre-tray.ps1",
    "tray:diagnostics": "powershell -NoProfile -ExecutionPolicy Bypass -File desktop/command-centre-tray.ps1 -DiagnosticsOnly",
    "daemon": "node scripts/daemon.mjs --root . --port 5178",
    "daemon:probe": "node scripts/daemon.mjs --root . --port 5191 --probe-once",
    "service:render": "node scripts/render-service-config.mjs",
    "pairing:list": "node scripts/midas.mjs pairing list",
    "test:pairing": "node scripts/test-pairing-gate.mjs",
    "test:workspace-router": "node scripts/test-workspace-router.mjs",
    "test:voice-gate": "node scripts/test-voice-gate.mjs",
    "test:model-router": "node scripts/test-model-router.mjs",
    "test:a2ui": "node scripts/test-a2ui-store.mjs",
    "test:sandbox": "node scripts/test-sandbox-runner.mjs",
    "test:mobile-node": "node scripts/test-mobile-node-intake.mjs"
  },
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ast-grep/napi": "^0.44.1",
    "smol-toml": "1.7.0",
    "yaml": "2.9.0"
  }
}
